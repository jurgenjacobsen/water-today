{
  "manifest_version": 3,
  "name": "Water Today",
  "version": "1.0.1",
  "description": "A simple extension to remind you to drink water throughout the day.",
  "permissions": [
    "alarms",
    "notifications",
    "storage",
    "offscreen"
  ],
  "background": {
    "service_worker": "scripts/background.js",
    "type": "module"
  },
  "icons": {
    "16": "assets/icon.png",
    "48": "assets/icon.png",
    "128": "assets/icon.png"
  },
  "action": {
    "default_title": "Water Today",
    "default_popup": "popup.html",
    "default_icon": "assets/icon.png"
  }
}